{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db:migrate": "ts-node lib/db/migrate.ts",
    "dev": "next dev",
    "check-secrets": "node scripts/check-client-secrets.js",
    "check-bundle-secrets": "ts-node scripts/check-bundle-secrets.ts",
    "build": "npm run check-secrets && next build && npm run check-bundle-secrets",
    "start": "next start",
    "lint": "next lint && npm run check-secrets",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:server": "vitest run --project server",
    "test:server:coverage": "vitest run --project server --coverage",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "svg": "node scripts/svgToComponent.js",
    "generate-component": "plop",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "create-pr": "node scripts/create-pr.js",
    "test:contract": "bash scripts/run-contract-tests.sh"
  },
  "dependencies": {
